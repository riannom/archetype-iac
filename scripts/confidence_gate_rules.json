{
  "version": 1,
  "doc_globs": [
    "*.md",
    "assets/**",
    "reports/**",
    "screenshots/**",
    "tasks/**"
  ],
  "default_checks": [],
  "fallback_checks": [
    "audit"
  ],
  "checks": {
    "audit": {
      "description": "Dry-run cleanup audit and baseline safety checks",
      "command": [
        "make",
        "audit"
      ],
      "required": true
    },
    "test-api": {
      "description": "API unit/integration suite",
      "command": [
        "make",
        "test-api"
      ],
      "required": true
    },
    "test-agent": {
      "description": "Agent unit/integration suite",
      "command": [
        "make",
        "test-agent"
      ],
      "required": true
    },
    "test-web-container": {
      "description": "Web vitest suite in containerized runner",
      "command": [
        "make",
        "test-web-container"
      ],
      "required": true
    },
    "test-observability-canary-script": {
      "description": "Script-level regression for observability canary auto-discovery",
      "command": [
        "python3",
        "-m",
        "pytest",
        "-q",
        "tests/scripts/test_observability_canary.py"
      ],
      "required": true
    },
    "test-api-observability-regression": {
      "description": "Targeted API regression for best-effort rollback handling",
      "command": [
        "/bin/bash",
        "-lc",
        "if command -v python3.11 >/dev/null 2>&1; then cd api && PYTHONPATH=\"${PYTHONPATH}:$(pwd)/..\" python3.11 -m pytest -q tests/test_tasks_jobs_advanced.py::TestCaptureNodeIps::test_commit_failure_rolls_back_session; elif docker ps --format '{{.Names}}' | grep -q '^archetype-iac-api-1$'; then docker exec archetype-iac-api-1 /bin/sh -lc 'cd /app && pytest -q tests/test_tasks_jobs_advanced.py::TestCaptureNodeIps::test_commit_failure_rolls_back_session'; else echo 'python3.11 is not available locally and API container archetype-iac-api-1 is not running.' >&2; exit 1; fi"
      ],
      "required": true
    },
    "observability-canary": {
      "description": "Read-only observability canary verification",
      "command": [
        "make",
        "observability-canary"
      ],
      "required": false
    }
  },
  "rules": [
    {
      "name": "api",
      "areas": [
        "api"
      ],
      "globs": [
        "api/**"
      ],
      "checks": [
        "test-api"
      ]
    },
    {
      "name": "api-observability-regressions",
      "areas": [
        "api",
        "observability"
      ],
      "globs": [
        "api/app/tasks/jobs.py",
        "api/tests/test_tasks_jobs_advanced.py"
      ],
      "checks": [
        "test-api-observability-regression"
      ]
    },
    {
      "name": "agent",
      "areas": [
        "agent"
      ],
      "globs": [
        "agent/**"
      ],
      "checks": [
        "test-agent"
      ]
    },
    {
      "name": "web",
      "areas": [
        "web"
      ],
      "globs": [
        "web/**"
      ],
      "checks": [
        "test-web-container"
      ]
    },
    {
      "name": "observability-script-tests",
      "areas": [
        "observability",
        "tooling"
      ],
      "globs": [
        "scripts/observability_canary.py",
        "tests/scripts/test_observability_canary.py"
      ],
      "checks": [
        "test-observability-canary-script"
      ]
    },
    {
      "name": "tooling",
      "areas": [
        "tooling"
      ],
      "globs": [
        ".github/**",
        "Makefile",
        "scripts/**",
        "tests/scripts/**"
      ],
      "checks": [
        "audit"
      ]
    },
    {
      "name": "runtime-compose",
      "areas": [
        "runtime"
      ],
      "globs": [
        "docker-compose*.yml",
        "Dockerfile*"
      ],
      "checks": [
        "test-api",
        "test-web-container",
        "audit"
      ]
    },
    {
      "name": "observability",
      "areas": [
        "observability"
      ],
      "globs": [
        "grafana/**",
        "prometheus*.yml",
        "promtail-config.yml",
        "scripts/observability_*",
        "scripts/run_observability_*",
        "scripts/install_observability_*"
      ],
      "checks": [
        "observability-canary"
      ]
    }
  ]
}
